# ClawHQ — copy to .env and fill in values
# Or just run ./install.sh and it will be written for you.

# ── Platform ──────────────────────────────────────────────────────────────
CLAWHQ_PUBLIC_URL=http://localhost:3500
CLAWHQ_PORT=3500
TZ=UTC

# ── Secrets (generate with: openssl rand -base64 32) ──────────────────────
POSTGRES_PASSWORD=
BETTER_AUTH_SECRET=
OPENCLAW_GATEWAY_TOKEN=
NEXTAUTH_SECRET=

# ── LLM Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Channels ──────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── OpenClaw ──────────────────────────────────────────────────────────────
OPENCLAW_PORT=18789
CLAUDE_AI_SESSION_KEY=

# ── Service Ports ─────────────────────────────────────────────────────────
OPENFANG_PORT=4200
PAPERCLIP_PORT=3100
