# ClawHQ — copy to .env and fill in values
# Or just run ./install.sh and it will be written for you.

# ── Platform ──────────────────────────────────────────────────────────────
# CLAWHQ_DOMAIN: your public domain (Caddy obtains TLS cert automatically)
# CLAWHQ_PUBLIC_URL: full URL shown in emails / OAuth redirects
CLAWHQ_DOMAIN=clawhq.example.com
CLAWHQ_PUBLIC_URL=https://clawhq.example.com
TZ=UTC

# ── Secrets (generate with: openssl rand -base64 32) ──────────────────────
POSTGRES_PASSWORD=
BETTER_AUTH_SECRET=
OPENCLAW_GATEWAY_TOKEN=
NEXTAUTH_SECRET=

# ── LLM Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Hermes channels (Hermes is the brain — give it your primary bot tokens) ─
# Create separate bots for Hermes vs OpenClaw so they don't conflict.
HERMES_DISCORD_BOT_TOKEN=
HERMES_TELEGRAM_BOT_TOKEN=
HERMES_SLACK_BOT_TOKEN=
HERMES_SLACK_APP_TOKEN=

# ── OpenClaw ──────────────────────────────────────────────────────────────
# OpenClaw uses its own bot tokens (separate from Hermes above).
# Leave blank if you only want Hermes handling channels.
OPENCLAW_PORT=18789
CLAUDE_AI_SESSION_KEY=

# ── Hermes Agent (Nous Research) ──────────────────────────────────────────
HERMES_PORT=4300
HERMES_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_API_KEY=

# ── Clawhip — event notification router ───────────────────────────────────
# Routes Git commits, GitHub events, tmux sessions, and agent lifecycle
# events to Discord or Slack. Use a dedicated bot (separate from Hermes).
# Create one at https://discord.com/developers/applications — grant "Send Messages".
# Use EITHER bot token OR webhook — not both.
CLAWHIP_DISCORD_TOKEN=
CLAWHIP_DISCORD_CHANNEL_ID=
CLAWHIP_DISCORD_WEBHOOK=
CLAWHIP_SLACK_WEBHOOK=
CLAWHIP_GITHUB_TOKEN=
# Comma-separated repos to watch: "owner/repo,owner/repo2"
CLAWHIP_GITHUB_REPOS=

# ── Service Ports ─────────────────────────────────────────────────────────
OPENFANG_PORT=4200
PAPERCLIP_PORT=3100
