{
  "name": "clawhq-platform",
  "compatibility_date": "2026-01-01",
  "main": "_worker.js",
  "assets": {
    "directory": "landing",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "clawhqplatform.com/*", "zone_name": "clawhqplatform.com" },
    { "pattern": "www.clawhqplatform.com/*", "zone_name": "clawhqplatform.com" }
  ]
}
