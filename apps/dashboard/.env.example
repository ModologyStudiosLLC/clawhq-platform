# ── WorkOS Auth (required) ──────────────────────────────────────────────────
# Get these from dash.workos.com → your app → API Keys
WORKOS_API_KEY=sk_live_...
WORKOS_CLIENT_ID=client_...
# Must match a Redirect URI registered in WorkOS dashboard
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3500/auth/callback
# 32+ char random secret: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=change_me_generate_a_32_char_secret_here

# ── Backend service URLs
# For local dev, these default to localhost in the code
# For production, point these at your deployed services

NEXT_PUBLIC_PAPERCLIP_URL=https://paperclip.yourdomain.com
NEXT_PUBLIC_OPENFANG_URL=https://openfang.yourdomain.com
NEXT_PUBLIC_OPENCLAW_URL=https://openclaw.yourdomain.com

# Optional: Analytics (Plausible)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=clawhq.yourdomain.com

# Pack Registry (required for premium packs)
PACK_REGISTRY_URL=https://packs.clawhqplatform.com
